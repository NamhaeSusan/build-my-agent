[project]
name = "{{component_name}}-ops-agent"
version = "0.1.0"
description = "Operational agent for {{component_name}}"
requires-python = ">=3.10"
dependencies = [
    "deepagents>=0.1.0",
    "langgraph>=0.2.0",
    "opensearch-py>=2.4.0",
    "prometheus-api-client>=0.5.0",
    "pydantic>=2.0",
    "pyyaml>=6.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.0",
    "pytest-asyncio>=0.23",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
